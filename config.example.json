{
  "app": {
    "name": "novel-pipeline-write-engine",
    "version": "0.5.6",
    "mode": "local"
  },
  "paths": {
    "db_path": "./data/novel_memory.db",
    "novels_root": "./novels",
    "exports_root": "./exports",
    "reports_root": "./exports/reports",
    "outputs_root": "./outputs",
    "tmp_root": "./tmp"
  },
  "novel": {
    "default_slug": "demo_novel",
    "default_title": "Demo Novel",
    "volume_dir_template": "\u7b2c{volume_no:02d}\u5377",
    "chapter_filename_template": "\u7b2c{chapter_no}\u7ae0_{chapter_title}.txt"
  },
  "gates": {
    "word_count": {
      "min_short_chapter": 500,
      "min_normal_chapter": 1300,
      "target_normal_chapter": 1900,
      "target_long_chapter": 3300
    },
    "allow_short_chapter": true,
    "short_chapter_reason_required": true
  },
  "report": {
    "write_json": true,
    "write_html": true
  }
}
